<puzzle-view class="hidden">
  <!-- Index child (path: '') for /fleet, /missions and /crew. A parent route
       with `children` only matches its bare path through an index child
       (D30), and this one deliberately renders nothing — it is the
       closed-panel state. Selecting a row navigates to the :id sibling, which
       swaps Detail.pzl into the same <Slot/> and plays its slide-in. No
       <script> needed: the compiler synthesizes an empty PuzzleView subclass. -->
</puzzle-view>

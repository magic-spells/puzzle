<puzzle-view>
  <div
    class="group relative flex items-center gap-2 pl-3 pr-2 py-2.5 rounded-xl cursor-pointer transition-colors {#if active}bg-accent/20 ring-1 ring-accent/40{/if}{#if !active}hover:bg-surface-2{/if}"
    @click={ handleSelect }>
    <div class="min-w-0 flex-1">
      <div class="truncate text-sm font-medium {#if active}text-fg{/if}{#if !active}text-muted group-hover:text-fg{/if}">{ conversation.displayTitle }</div>
      <div class="text-[11px] text-faint">{ conversation.updatedAt | timeago }</div>
    </div>

    <!-- Delete. @click:stop (v1.7, D38) keeps the click from bubbling to the row's
         @click, so removing a thread never also selects it. -->
    <button
      type="button"
      class="shrink-0 w-7 h-7 grid place-items-center rounded-lg text-faint opacity-0 group-hover:opacity-100 hover:bg-surface hover:text-fg transition"
      aria-label="Delete conversation"
      @click:stop={ handleDelete }>
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg>
    </button>
  </div>
</puzzle-view>

<script>
import { PuzzleView } from '@magic-spells/puzzle';

// A sidebar row. `select` and `delete` are callback props (D16): the parent
// binds @select / @delete with the conversation already closed over, so this
// row just invokes them.
export default class ConversationItem extends PuzzleView {
  data(params, props) {
    // findOne (not the prop itself) so this row subscribes to its own record —
    // in-place record mutation is invisible to prop-diffing, and the title and
    // updatedAt change over the conversation's life (auto-title, new messages).
    return {
      conversation: this.ctx.store.findOne('conversation', props.conversation.id) ?? props.conversation,
      active: props.active || false,
    };
  }

  events = {
    handleSelect: () => {
      if (typeof this.props.select === 'function') this.props.select();
    },
    handleDelete: () => {
      if (typeof this.props.delete === 'function') this.props.delete();
    },
  };

  // Staggered entrance: each row's `in` is delayed by its index prop, so a
  // freshly-rendered list cascades in (mirrors mission-control's ListRow). The
  // `to` keyframe is the row's resting style — WAAPI releases the fill on finish.
  get animations() {
    const i = this.props.index ?? 0;
    return {
      in:  { from: { opacity: 0, transform: 'translateX(-8px)' }, to: { opacity: 1, transform: 'translateX(0)' }, duration: 260, delay: i * 40, easing: 'ease-out' },
      out: { from: { opacity: 1, transform: 'translateX(0)' }, to: { opacity: 0, transform: 'translateX(-8px)' }, duration: 140, easing: 'ease-in' },
    };
  }
}
</script>
